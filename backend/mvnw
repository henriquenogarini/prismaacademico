#!/bin/sh
# Maven Wrapper Script for Unix/macOS/Linux
MAVEN_PROJECTBASEDIR=$(dirname "$0")
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
  wrapperUrl=$(grep '^wrapperUrl=' "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
  if [ -n "$wrapperUrl" ]; then
    DOWNLOAD_URL="$wrapperUrl"
  fi
fi

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  echo "Downloading Maven Wrapper JAR from $DOWNLOAD_URL..."
  if command -v curl > /dev/null; then
    curl -o "$MAVEN_WRAPPER_JAR" "$DOWNLOAD_URL"
  elif command -v wget > /dev/null; then
    wget -O "$MAVEN_WRAPPER_JAR" "$DOWNLOAD_URL"
  else
    echo "Cannot download Maven Wrapper. Please install curl or wget."
    exit 1
  fi
fi

exec "$JAVA_HOME/bin/java" -jar "$MAVEN_WRAPPER_JAR" "$@"

