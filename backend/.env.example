# ============================================================
# Prisma Acadêmico - Exemplo de Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA versione o arquivo .env com credenciais reais.

# Aplicação
APP_NAME=Prisma Acadêmico
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Banco de Dados
DB_HOST=postgres
DB_PORT=5432
DB_NAME=prisma_academico
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha_segura
DB_URL=jdbc:postgresql://postgres:5432/prisma_academico

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_redis_opcional

# JWT - Use uma chave de pelo menos 256 bits (32+ caracteres aleatórios)
JWT_SECRET=sua-chave-jwt-secreta-de-pelo-menos-256-bits-aqui
JWT_EXPIRATION_MINUTES=120
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS - origens permitidas separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Swagger
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
SPRINGDOC_API_DOCS_PATH=/v3/api-docs

